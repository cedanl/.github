{
  "$schema": "npuls-design-tokens-v1",
  "colors": {
    "primary": {
      "npuls-oranje": "#DD784B",
      "npuls-zwart":  "#000000",
      "npuls-roze":   "#F4D9DC",
      "npuls-blauw":  "#3D68EC",
      "npuls-geel":   "#F4D74B",
      "npuls-groen":  "#00AF81",
      "npuls-wit":    "#FFFFFF"
    },
    "secondary": {
      "licht-groen":  "#CCEEE6",
      "licht-blauw":  "#D6E2FD",
      "licht-roze":   "#FAEAEA",
      "licht-oranje": "#FFE4D8",
      "licht-geel":   "#FCF5D4"
    },
    "rules": {
      "min_primary_colors_per_design": 3,
      "npuls-zwart_usage": "alleen voor typografie, nooit als achtergrondkleur",
      "secondary_usage": "achtergronden of illustratie-details, ter ondersteuning van leesbaarheid"
    },
    "allowed_combinations": [
      { "background": "npuls-blauw",  "with": ["npuls-geel", "npuls-roze"] },
      { "background": "npuls-roze",   "with": ["npuls-blauw", "npuls-groen", "npuls-zwart", "npuls-oranje"] },
      { "background": "npuls-geel",   "with": ["npuls-oranje", "npuls-zwart", "npuls-blauw"] },
      { "background": "npuls-groen",  "with": ["npuls-roze", "npuls-zwart"] },
      { "background": "npuls-oranje", "with": ["npuls-zwart", "npuls-roze"] },
      { "background": "npuls-zwart",  "with": ["npuls-blauw", "npuls-oranje", "npuls-groen", "npuls-geel", "npuls-roze"] }
    ],
    "forbidden_examples": ["geel-op-groen", "groen-op-blauw"]
  },
  "typography": {
    "primary_font": {
      "name": "General Sans",
      "digital_fallback": "Plus Jakarta Sans (Google Fonts)",
      "weights": ["Regular (400)", "SemiBold (600)"]
    },
    "secondary_fonts": {
      "cooper_light": { "usage": "introducties, ondertitels, quotes" },
      "kansas_regular": { "usage": "projectasset, laden via @font-face", "license": "commercieel" }
    },
    "scale": {
      "h1": { "size": "40-56px", "weight": "SemiBold" },
      "h2": { "size": "28-36px", "weight": "SemiBold" },
      "h3": { "size": "20-24px", "weight": "SemiBold" },
      "body": { "size": "16px", "weight": "Regular" },
      "label": { "size": "12-13px", "weight": "SemiBold", "transform": "uppercase", "letter_spacing": "0.08em" }
    }
  },
  "icons": {
    "library": "Font Awesome",
    "style": "solid-sharp",
    "cdn": true,
    "color_rule": "altijd een paletkleur + passende achtergrond, kleurparen afwisselen"
  },
  "shapes": {
    "kernvormen": [
      { "naam": "Pulse curve", "vorm": "golvende lijn", "betekenis": "dynamiek" },
      { "naam": "Concentrische ringen", "vorm": "ringen rond middelpunt", "betekenis": "bron van impact, kenniscentrum" },
      { "naam": "Chevron / pijl", "vorm": "punt/pijl", "betekenis": "richting, vooruitgang" },
      { "naam": "Starburst", "vorm": "stervorm", "betekenis": "aandacht, nieuw" },
      { "naam": "Boog / halfcirkel", "vorm": "boog", "betekenis": "verbinding, overgang" }
    ],
    "usage_rule": "altijd in een paletkleur + passende achtergrond, ook inzetbaar als decoratief masker"
  },
  "photography": {
    "keywords": ["Focus", "Innovatie", "Actief", "Kleurrijk"],
    "sources": [
      "https://www.flickr.com/groups/cczero/pool/",
      "https://www.flickr.com/groups/publicdomain/pool/"
    ],
    "mask_with_kernvormen": true
  },
  "logo": {
    "payoff_text": "Onderwijs bewegen.",
    "payoff_font": "General Sans Semibold",
    "payoff_placement": "altijd separaat van het logo, hoek vrij te kiezen",
    "clearspace_rule": "minimaal zo groot als de letter 'N' rondom het logo",
    "orientation_preference": "horizontaal, verticaal toegestaan bij kleine/vierkante ruimtes",
    "icon_only_context": "favicon, app-icoon, andere zeer beperkte ruimtes",
    "initiative_label": "optioneel label met paletkleur te koppelen aan events/initiatieven"
  },
  "license": {
    "type": "CC BY-SA 4.0",
    "logo_and_brand_marks_excluded": true,
    "note": "aanpassingen aan logo's/merkidentiteitselementen alleen met expliciete toestemming"
  }
}
